<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <RelativeLayout
        android:layout_width="200dp"
        android:layout_height="200dp">

        <ImageView
            android:id="@+id/ivFile1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:src="@drawable/ic_file_vector"
            app:tint="?attr/colorOnPrimary" />

        <ImageView
            android:id="@+id/ivFile2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_below="@id/ivFile1"
            android:layout_marginTop="20dp"
            android:layout_toStartOf="@id/ivFile1"
            android:src="@drawable/ic_file_vector"
            app:tint="?attr/colorOnPrimary" />

        <ImageView
            android:id="@+id/ivFile3"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_below="@id/ivFile1"
            android:layout_marginTop="20dp"
            android:layout_toEndOf="@id/ivFile1"
            android:src="@drawable/ic_file_vector"
            app:tint="?attr/colorOnPrimary" />

        <ImageView
            android:id="@+id/ivVault"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_vault_vector"
            app:tint="?attr/colorOnPrimary" />

    </RelativeLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:gravity="center"
        android:text="@string/intro_hiding_title"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/intro_hiding_description"
        android:textColor="?attr/colorOnPrimarySecondary"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="@string/hiding_step_selecting"
        android:textColor="?attr/colorOnPrimary"
        android:textSize="16sp" />

    <ProgressBar
        android:id="@+id/progressIndicator"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="16dp"
        android:progress="0"
        android:progressTint="?attr/colorOnPrimary" />

</LinearLayout>
